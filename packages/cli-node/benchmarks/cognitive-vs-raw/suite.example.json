{
  "name": "cognitive-vs-raw-example",
  "description": "Small benchmark suite for structured extraction and PR review gate tasks.",
  "defaults": {
    "temperature": 0.2,
    "maxTokens": 1200
  },
  "cases": [
    {
      "id": "incident-triage-extraction",
      "kind": "structured-extraction",
      "description": "Turn an incident description into a fixed triage object.",
      "taskPrompt": "Read the incident text and extract a compact triage object for an engineering on-call workflow.",
      "input": {
        "text": "Users report that login fails after password reset on iOS. Support received 12 tickets in two hours. The temporary workaround is to retry in the web client. The app shows 'reset token expired' even when the link is fresh."
      },
      "targetSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["issue_type", "severity", "affected_surface", "impact_scope", "workaround_status", "next_action_code"],
        "properties": {
          "issue_type": {
            "type": "string",
            "enum": ["password_reset_login_failure"],
            "description": "Use the canonical triage taxonomy label, not a free-form sentence.",
            "x-cognitive-string-normalize": "lower_snake_case"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"],
            "description": "Choose high when a user-facing authentication flow is broken on a production platform and support volume is already elevated. Reserve critical for cross-platform outage or no workaround."
          },
          "affected_surface": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["ios", "login", "password_reset"],
              "x-cognitive-string-normalize": "lower_snake_case"
            },
            "minItems": 2,
            "description": "Return canonical surface labels only. Use ios for the platform, login for the failed auth path, and password_reset for the triggering workflow.",
            "x-cognitive-unordered": true
          },
          "impact_scope": {
            "type": "string",
            "enum": ["login_blocked_after_password_reset"],
            "description": "Use the canonical impact label, not a prose sentence.",
            "x-cognitive-string-normalize": "lower_snake_case"
          },
          "workaround_status": {
            "type": "string",
            "enum": ["web_client_retry_available"],
            "description": "Use the canonical workaround label.",
            "x-cognitive-string-normalize": "lower_snake_case"
          },
          "next_action_code": {
            "type": "string",
            "enum": ["inspect_reset_token_validation"],
            "description": "Use the canonical next action label naming the reset token validation path.",
            "x-cognitive-string-normalize": "lower_snake_case"
          }
        }
      },
      "semanticChecks": [
        { "path": "issue_type", "type": "equals", "value": "password_reset_login_failure" },
        { "path": "severity", "type": "equals", "value": "high" },
        { "path": "affected_surface", "type": "array_includes_all", "value": ["ios", "password_reset"] },
        { "path": "impact_scope", "type": "equals", "value": "login_blocked_after_password_reset" },
        { "path": "workaround_status", "type": "equals", "value": "web_client_retry_available" },
        { "path": "next_action_code", "type": "equals", "value": "inspect_reset_token_validation" }
      ]
    },
    {
      "id": "product-brief-extraction",
      "kind": "structured-extraction",
      "description": "Turn a product brief into a stable launch-summary object.",
      "taskPrompt": "Read the product brief and extract the launch audience, primary goal, proof points, and constraints.",
      "input": {
        "query": "We are launching a resilience supplement for urban professionals aged 25-45. The main promise is stress recovery support during high-pressure work cycles. The landing page should stay conservative on claims, avoid medical promises, and highlight three proof points: ingredient transparency, daily usability, and third-party testing."
      },
      "targetSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["audience", "primary_goal", "proof_points", "constraints"],
        "properties": {
          "audience": { "type": "string" },
          "primary_goal": { "type": "string" },
          "proof_points": {
            "type": "array",
            "items": { "type": "string", "x-cognitive-string-normalize": "lowercase" },
            "minItems": 2,
            "x-cognitive-unordered": true
          },
          "constraints": {
            "type": "array",
            "items": { "type": "string", "x-cognitive-string-normalize": "lowercase" },
            "minItems": 2,
            "x-cognitive-unordered": true
          }
        }
      },
      "semanticChecks": [
        { "path": "proof_points", "type": "min_items", "value": 2 },
        { "path": "constraints", "type": "min_items", "value": 2 }
      ]
    },
    {
      "id": "pr-review-sql-injection",
      "kind": "pr-review-gate",
      "description": "Review insecure login code and return a fixed review object.",
      "taskPrompt": "Review the code for correctness and security risk. Focus on issues that would matter in a pull-request gate.",
      "input": {
        "code": "def login(user, password):\n    query = f\"SELECT * FROM users WHERE name = '{user}' AND password = '{password}'\"\n    return db.execute(query).fetchone()"
      },
      "targetSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision", "risk", "blocking", "findings"],
        "properties": {
          "decision": {
            "type": "string",
            "enum": ["reject_until_security_fix"],
            "description": "Use the canonical gate decision label, not a sentence.",
            "x-cognitive-string-normalize": "lower_snake_case"
          },
          "risk": { "type": "string", "enum": ["none", "low", "medium", "high"], "description": "Use high for directly exploitable SQL injection on an authentication path." },
          "blocking": { "type": "boolean", "description": "Must be true when the issue should stop the PR from merging." },
          "findings": {
            "type": "array",
            "minItems": 1,
            "x-cognitive-unordered": true,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["finding_type", "severity", "category", "affected_path", "remediation"],
              "properties": {
                "finding_type": {
                  "type": "string",
                  "enum": ["sql_injection"],
                  "x-cognitive-string-normalize": "lower_snake_case"
                },
                "severity": { "type": "string", "enum": ["low", "medium", "high"], "description": "Use high for directly exploitable auth-path security issues." },
                "category": { "type": "string", "enum": ["security", "correctness", "reliability", "maintainability"] },
                "affected_path": {
                  "type": "string",
                  "enum": ["authentication_path"],
                  "x-cognitive-string-normalize": "lower_snake_case"
                },
                "remediation": {
                  "type": "string",
                  "enum": ["parameterized_queries"],
                  "x-cognitive-string-normalize": "lower_snake_case"
                }
              }
            }
          }
        }
      },
      "semanticChecks": [
        { "path": "decision", "type": "equals", "value": "reject_until_security_fix" },
        { "path": "risk", "type": "equals", "value": "high" },
        { "path": "blocking", "type": "equals", "value": true },
        { "path": "findings", "type": "min_items", "value": 1 },
        { "path": "findings", "type": "array_object_any", "field": "category", "matcher": "equals", "value": "security" },
        { "path": "findings", "type": "array_object_any", "field": "severity", "matcher": "equals", "value": "high" },
        { "path": "findings", "type": "array_object_any", "field": "finding_type", "matcher": "equals", "value": "sql_injection" },
        { "path": "findings", "type": "array_object_any", "field": "affected_path", "matcher": "equals", "value": "authentication_path" },
        { "path": "findings", "type": "array_object_any", "field": "remediation", "matcher": "equals", "value": "parameterized_queries" }
      ]
    },
    {
      "id": "pr-review-input-validation",
      "kind": "pr-review-gate",
      "description": "Review an API diff that accepts unvalidated input.",
      "taskPrompt": "Review the diff and return a release-gate style decision object. Focus on validation and operational risk.",
      "input": {
        "diff": "diff --git a/server.js b/server.js\n@@\n-app.post('/export', requireAuth, async (req, res) => {\n-  const job = await queueExport({ userId: req.user.id });\n+app.post('/export', requireAuth, async (req, res) => {\n+  const job = await queueExport({ userId: req.user.id, format: req.body.format, filters: req.body.filters, email: req.body.email });\n   res.json({ id: job.id });\n })"
      },
      "targetSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision", "risk", "requires_changes", "key_issues"],
        "properties": {
          "decision": {
            "type": "string",
            "enum": ["reject_until_validation_added"],
            "description": "Use the canonical gate decision label, not a sentence.",
            "x-cognitive-string-normalize": "lower_snake_case"
          },
          "risk": { "type": "string", "enum": ["none", "low", "medium", "high"], "description": "Use high when unvalidated input directly affects export jobs or outbound email behavior." },
          "requires_changes": { "type": "boolean", "description": "Must be true if the diff should be blocked pending validation or sanitization." },
          "key_issues": {
            "type": "array",
            "minItems": 1,
            "x-cognitive-unordered": true,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["issue_type", "severity", "impact_surface", "remediation"],
              "properties": {
                "issue_type": {
                  "type": "string",
                  "enum": ["missing_input_validation"],
                  "x-cognitive-string-normalize": "lower_snake_case"
                },
                "severity": { "type": "string", "enum": ["low", "medium", "high"], "description": "Use high when the issue can trigger unsafe jobs or notification abuse." },
                "impact_surface": {
                  "type": "string",
                  "enum": ["export_job_and_email_input"],
                  "x-cognitive-string-normalize": "lower_snake_case"
                },
                "remediation": {
                  "type": "string",
                  "enum": ["validate_and_sanitize_request_fields"],
                  "x-cognitive-string-normalize": "lower_snake_case"
                }
              }
            }
          }
        }
      },
      "semanticChecks": [
        { "path": "decision", "type": "equals", "value": "reject_until_validation_added" },
        { "path": "risk", "type": "equals", "value": "high" },
        { "path": "requires_changes", "type": "equals", "value": true },
        { "path": "key_issues", "type": "min_items", "value": 1 },
        { "path": "key_issues", "type": "array_object_any", "field": "issue_type", "matcher": "equals", "value": "missing_input_validation" },
        { "path": "key_issues", "type": "array_object_any", "field": "severity", "matcher": "equals", "value": "high" },
        { "path": "key_issues", "type": "array_object_any", "field": "impact_surface", "matcher": "equals", "value": "export_job_and_email_input" },
        { "path": "key_issues", "type": "array_object_any", "field": "remediation", "matcher": "equals", "value": "validate_and_sanitize_request_fields" }
      ]
    }
  ]
}
